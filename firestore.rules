rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: User is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: User is Admin
    // Checks the 'users' collection for the user's role document
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection ---
    // Critical for Role Management
    match /users/{userId} {
      // Users can read their own role profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Only Admins can create/modifiers users/roles
      allow write: if isAdmin();
    }

    // --- Production Collections ---
    match /members/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /subscriptions/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /donations/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /arrears/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Developer / Debug Collections ---
    match /dev_members/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /dev_subscriptions/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /dev_donations/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /dev_arrears/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /dev_config/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
